<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/booksImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@drawable/ic_launcher_background"
        app:layout_constraintWidth_percent="0.3"
        app:layout_constraintDimensionRatio="H, 2:3"
        />

    <TextView
        android:id="@+id/booksTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Harry Potter and the Sorcerer's Stone"
        app:layout_constraintStart_toEndOf="@+id/booksImage"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/bookRelease"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1997"
        app:layout_constraintStart_toEndOf="@+id/booksImage"
        app:layout_constraintTop_toBottomOf="@+id/booksTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>